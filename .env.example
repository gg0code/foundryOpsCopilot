# FoundryOps Copilot — environment template.
# Copy this file to `.env` (same folder, git-ignored) and fill in ONE provider key
# to enable the /ask conversational assistant. The rest of the demo needs nothing here.
#
#   cp .env.example .env      # macOS/Linux
#   copy .env.example .env    # Windows
#
# Real shell environment variables override anything set here.

# --- Option A: Claude (preferred if set) ---
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- Option B: Groq (OpenAI-compatible, fast/low-cost) ---
GROQ_API_KEY=gsk_xxxxxxxx
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=openai/gpt-oss-120b
